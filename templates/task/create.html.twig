{% extends 'base.html.twig' %}

{% block body %}

	{{ form_start(form) }}

	<div class="max-w-3xl p-16 mx-auto my-12 bg-indigo-200 shadow-lg rounded-3xl text-black">

		<h1 class="text-3xl font-bold text-center">Create Task</h1>

		{% for message in app.flashes('success_save') %}
			<div class="flex items-center bg-green-500 text-black p-3 mb-3 rounded-xl w-full relative">

				<span class="flex-1 text-center">
					{{ message }}
				</span>

				<button onclick="this.parentElement.remove()" class="text-red-900 font-bold absolute right-3" style="cursor: pointer;">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
						<path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
					</svg>
				</button>

			</div>
		{% endfor %}
		{% for message in app.flashes('failed_save') %}
			<div class="flex items-center bg-red-200 text-black p-3 mb-3 rounded-xl w-full relative">
				<span class="flex-1 text-center">
					{{ message }}
				</span>
				<button onclick="this.parentElement.remove()" class="text-red-900 font-bold absolute right-3" style="cursor: pointer;">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
						<path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
					</svg>
				</button>
			</div>
		{% endfor %}

		<div class="mb-6">
			{{ form_label(form.title, null, { 
                label_attr: { class: 'block mb-1 font-bold'} 
            }) }}

			{{ form_widget(form.title, {
                attr: { class: 'w-full p-2 border rounded bg-yellow-50', autocomplete: 'off'}
             }) }}

			{{ form_errors(form.title) }}
		</div>

		<div class="my-6">
			{{ form_label(form.description, null, { 
                label_attr: { class: 'block mb-1 font-bold' } 
            }) }}

			{{ form_widget(form.description, {
                attr: { class: 'w-full p-2 border rounded bg-yellow-50', autocomplete: 'off' }
             }) }}

			{{ form_errors(form.description) }}
		</div>

		<div class="mt-auto flex justify-self-end">
			<button id="saveCreate" class="bg-indigo-800 text-white py-2 px-4 rounded-md shadow-md transition hover:-translate-y-1 hover:bg-indigo-400 hover:text-black hover:shadow-3xl" style="cursor: pointer;">
				Add
			</button>
		</div>

	</div>

	{{ form_end(form) }}

{% endblock %}

{% extends 'base.html.twig' %}
{% block body %}
	<div class="px-12 my-12">
		<div class="p-16 bg-indigo-200 shadow-lg rounded-3xl text-black">
			<h1 class="flash-show font-bold text-center text-3xl mb-6">Task List</h1>
			<div class="rounded-2xl overflow-hidden">
				<table class="table-fixed w-full text-center">

					<thead>
						<tr>
							<th class="bg-indigo-50 font-bold text-2xl px-4 py-12">Title</th>
							<th class="bg-indigo-50 font-bold text-2xl px-4 py-12">Status</th>
							<th class="bg-indigo-50 font-bold text-2xl px-4 py-12">Created Date</th>
							<th class="bg-indigo-50 font-bold text-2xl px-4 py-12">Actions</th>
						</tr>
					</thead>

					{% for task in data_table %}

						<tr data-id="{{ task.id }}" class="hover:text-black hover:bg-indigo-50 text-lg bg-indigo-100">
							<td class="p-6">{{ task.title }}</td>
							<td class="p-6">
								{% set statusClasses = {
									'pending': 'bg-gray-500 p-4 text-white rounded-md',
									'in_progress': 'bg-yellow-500 p-4 rounded-md',
									'done' : 'bg-green-500 p-4 rounded-md'
									}
								 %}
								{%
								 set statusText = {
										'pending': 'Pending',
										'in_progress': 'In Progress',
										'done': 'Done'
									}
								 %}
								<span class="{{ statusClasses[task.status] }}">
									{{ statusText[task.status] }}
								</span>
							</td>
							<td class="p-6">{{ task.createdAt|date('Y-m-d H:i') }}</td>
							<td class="p-6">
								<button class="edit-btn p-2 rounded shadow-2xl bg-indigo-800 text-white mx-4 transition hover:-translate-y-1 hover:shadow-3xl hover:bg-blue-600" data-id="{{ task.id }}" data-title="{{ task.title }}" data-description="{{ task.description }}" data-status="{{task.status}}" style="cursor: pointer;">
									Edit
								</button>
								<button class="delete-btn p-2 rounded shadow-2xl bg-red-800 text-white mx-4 transition hover:-translate-y-1 hover:shadow-3xl hover:bg-red-600" data-id="{{ task.id }}" style="cursor: pointer;">
									Delete
								</button>
							</td>
						</tr>

					{% else %}
						<tr class="hover:text-black hover:bg-indigo-50 text-lg bg-indigo-100" style="cursor: pointer;">
							<th class="text-center p-21" colspan="4">No tasks found</th>
						</tr>
					{% endfor %}
				</table>
			</div>

		</div>
	</div>

	<div id="editModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center">

		<div class="bg-indigo-200 p-6 m-12 rounded-xl shadow-xl w-md h-md">
			<h2 class="text-3xl font-bold mb-6 text-center mb-6">Edit Task</h2>

			<label for="editTitle" class="text-lg block mb-1 font-bold">Title</label>
			<input id="editTitle" class="bg-white w-full p-2 border rounded mb-6 bg-yellow-50" placeholder="Title" autocomplete="off" required>

			<label for="editStatus" class="block mb-1 font-bold">Status</label>
			<select id="editStatus" class="bg-white w-full p-4 border rounded mb-6 bg-yellow-50">
				<option value="pending">Pending</option>
				<option value="in_progress">In Progress</option>
				<option value="done">Done</option>
			</select>

			<label for="editDescription mb-2" class="block mb-1 font-bold">Description</label>
			<textarea id="editDescription" class="bg-white w-full p-2 border rounded mb-6 bg-yellow-50" rows="3" style="resize: none;" autocomplete="off"></textarea>

			<div class="flex justify-center gap-6 my-6">
				<button id="saveEdit" class="bg-green-700 px-3 py-2 rounded-md text-white shadow-3xl transition hover:-translate-y-1 hover:shadow-3xl hover:bg-green-600" style="cursor: pointer;">Save</button>
				<button id="closeEdit" class="bg-red-700 px-4 py-2 rounded-md text-white shadow-3xl transition hover:-translate-y-1 hover:shadow-3xl hover:bg-red-600" style="cursor: pointer;">Cancel</button>
			</div>
		</div>

	</div>

	<div id="deleteModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center">

		<div class="bg-indigo-200 p-6 m-12 rounded-xl shadow-xl w-md h-md text-center ">

			<h2 class="text-3xl font-bold my-6">Delete</h2>
			<p class="my-6 text-xl">Are you sure you want to delete this?</p>

			<div class="flex justify-center gap-6 my-6">
				<button id="confirmBtn" class="bg-green-700 px-3 py-2 rounded-md text-white shadow-3xl transition hover:-translate-y-1 hover:shadow-3xl hover:bg-green-600" style="cursor: pointer;">
					Yes
				</button>
				<button id="cancelBtn" class="bg-red-700 px-4 py-2 rounded-md text-white shadow-3xl transition hover:-translate-y-1 hover:shadow-3xl hover:bg-red-600" style="cursor: pointer;">
					No
				</button>
			</div>

		</div>
	</div>
{% endblock %}
